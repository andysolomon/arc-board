{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://arc.dev/schema/handoff.json",
  "title": "Handoff",
  "type": "object",
  "required": [
    "status",
    "summary",
    "changes",
    "verification",
    "risks",
    "next_actions"
  ],
  "properties": {
    "status": {
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

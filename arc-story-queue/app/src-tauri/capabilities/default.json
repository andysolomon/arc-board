{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:7420" },
        { "url": "http://127.0.0.1:7420" }
      ]
    }
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    // Keep test typechecking on arc-contracts source, matching tsconfig.json
    // and the vite/vitest aliases (W-000033).
    "paths": {
      "arc-contracts": ["../packages/arc-contracts/src/index.ts"]
    }
  },
  "include": ["vite.config.ts", "test/**/*"]
}

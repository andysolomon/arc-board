{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    // Resolve arc-contracts from source so the app never typechecks against a
    // stale dist build (W-000033). Node consumers (mcp-server) still use dist.
    "paths": {
      "arc-contracts": ["../packages/arc-contracts/src/index.ts"]
    }
  },
  "include": ["src"]
}
